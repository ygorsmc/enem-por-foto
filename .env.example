# ── Ambiente ────────────────────────────────────────────────────────────────
# "local" desliga a verificação de assinatura dos webhooks (testes com simulate.py/ngrok).
ENVIRONMENT=local
LOG_LEVEL=INFO

# Canal padrão dos webhooks sem canal explícito ("whatsapp" | "telegram").
# Telegram é o recomendado: a partir de 01/10/2026 o WhatsApp Business Platform
# passa a cobrar por mensagem de serviço (ver README, seção "Conectando os canais").
CHANNEL_BACKEND=telegram

# ── Redis (estado da conversa, consentimento, rate-limit, idempotência) ────
# Local/dev: Redis embutido no contêiner. Deploy scale-to-zero (Azure minReplicas=0):
# use um Redis EXTERNO (ex.: Upstash, rediss://...) — o embutido morre quando a
# réplica dorme e leva o estado da conversa junto. Ver deploy/README.md.
REDIS_URL=redis://localhost:6379/0
# Prefixo opcional em todas as chaves Redis. Útil se este banco for
# compartilhado entre múltiplos ambientes/deploys, evitando colisão de estado
# (flow/consent/rate-limit) entre eles. Vazio = sem prefixo.
REDIS_NAMESPACE=

# ── Job dispatch / fila (webhook → processamento OCR+LLM) ───────────────────
# "memory" (default): asyncio.create_task no mesmo processo (mono-contêiner,
#   minReplicas=1). Usado por dev, simulate.py e testes.
# "azure": enfileira numa Azure Storage Queue drenada por um worker — habilita
#   scale-to-zero no Azure Container Apps com KEDA azure-queue scaler.
QUEUE_BACKEND=memory
# Só quando QUEUE_BACKEND=azure:
AZURE_STORAGE_CONNECTION_STRING=
ESSAY_QUEUE_NAME=essay-jobs
QUEUE_VISIBILITY_TIMEOUT=300
QUEUE_POLL_INTERVAL=3

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v25.0
PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
NGROK_URL=

# ── Telegram Bot API ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
BOT=

# Obrigatório em produção: setWebhook DEVE passar secret_token=TELEGRAM_WEBHOOK_SECRET.
TELEGRAM_WEBHOOK_SECRET=

# ── OCR (Mistral) e correção (provedor plugável) ────────────────────────────
MISTRAL_API_KEY=
# Provedor da correção: "gemini" | "claude" | "openai" | "deepseek" | "maritaca".
# Troca rápida para comparar modelos — CORRECTION_MODEL usa o nome do modelo
# NO provedor escolhido (ex.: gemini-3.5-flash, claude-sonnet-5, gpt-5,
# deepseek-v4-flash, sabia-4/sabiazinho-4 na Maritaca).
CORRECTION_PROVIDER=deepseek
CORRECTION_MODEL=deepseek-v4-flash
# "claude": low | medium | high | max (e xhigh no Sonnet 5).
# "deepseek" (V4 Flash/Pro): liga o thinking mode; só high | max (a API já
# mapeia low/medium→high e xhigh→max). Ignorado nos outros provedores
# (maritaca incluído — não tem parâmetro de effort documentado).
CORRECTION_EFFORT=max
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MARITACA_API_KEY=

# ── Limites ─────────────────────────────────────────────────────────────────
# Correções por aluno por dia (correção é o fluxo caro: OCR + LLM).
ESSAY_DAILY_LIMIT=2
